          "expr": "tsa_physical_bitrate_bps{stream_id=\"$stream\"}",
          "legendFormat": "Physical"
        },
        {
          "expr": "tsa_pcr_bitrate_bps{stream_id=\"$stream\"}",
          "legendFormat": "Logical"
        }
      ],
      "fieldConfig": {
        "defaults": {
