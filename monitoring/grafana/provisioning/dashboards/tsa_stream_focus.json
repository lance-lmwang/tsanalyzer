{
  "uid": "stream-focus",
  "title": "TsAnalyzer Pro - STREAM FOCUS",
  "refresh": "5s",
  "schemaVersion": 36,
  "version": 1,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "stream",
        "type": "query",
        "query": "label_values(tsa_health_score, stream_id)",
        "refresh": 1,
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "label": "Focus Stream"
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "TIER 1: MASTER CONTROL CONSOLE (SIGNAL STATUS)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "SIGNAL PRESENCE",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_signal_lock_status{stream_id=\"$stream\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "LOST",
                  "color": "red"
                },
                "1": {
                  "text": "LOCKED",
                  "color": "green"
                }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "gauge",
      "title": "SIGNAL FIDELITY",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_health_score{stream_id=\"$stream\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent"
        }
      }
    },
    {
      "type": "stat",
      "title": "ENGINE DETERMINISM",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_internal_analyzer_drop{stream_id=\"$stream\"}",
          "legendFormat": "Drops"
        },
        {
          "expr": "tsa_worker_slice_overruns{stream_id=\"$stream\"}",
          "legendFormat": "Overruns"
        }
      ]
    },
    {
      "type": "row",
      "title": "TIER 2: TRANSPORT & LINK INTEGRITY (SRT/MDI)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Link Capacity",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_physical_bitrate_bps{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "SRT NAK",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 6,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_srt_nak_count{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "SRT RTT",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_srt_rtt_ms{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "MDI DF",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "mdi_df{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "row",
      "title": "TIER 3: ETR 290 P1 (CRITICAL COMPLIANCE)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Sync Loss",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_tr101290_p1_sync_loss{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PAT Error",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 6,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_tr101290_p1_pat_error{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PMT Error",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_tr101290_p1_pmt_error{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "CC Error",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_tr101290_p1_cc_error{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "row",
      "title": "TIER 4: ETR 290 P2 (CLOCK & TIMING)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "PCR JITTER & ACCURACY",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_pcr_jitter_ms{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "row",
      "title": "TIER 5: SERVICE PAYLOAD DYNAMICS (MUX)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "PID BITRATE REVENUE",
      "gridPos": {
        "h": 15,
        "w": 18,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (pid, type) (tsa_pid_bitrate_bps{stream_id=\"$stream\"})"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "type": "row",
      "title": "TIER 6: ESSENCE QUALITY & TEMPORAL STABILITY",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "collapsed": false
    },
    {
      "type": "row",
      "title": "TIER 7: ALARM RECAP & FORENSIC AUDIT TRAIL",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 44
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "ALARM EVENT LOG",
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 45
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "increase(tsa_tr101290_p1_cc_error{stream_id=\"$stream\"}[1h]) > 0",
          "format": "table"
        }
      ]
    }
  ],
  "editable": true
}