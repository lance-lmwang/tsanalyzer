    {
      "title": "P1.1 Sync Loss",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 0,
        "y": 10
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "tsa_tr101290_p1_sync_loss{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "green",
                  "text": "OK"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 0.1,
                "to": 1000000000000.0,
                "result": {
                  "color": "red",
                  "text": "ALARM"
                }
              }
            }
          ]
        }
      }
    },
