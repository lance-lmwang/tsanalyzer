{
  "uid": "stream-focus",
  "title": "TsAnalyzer Pro - STREAM FOCUS",
  "refresh": "5s",
  "schemaVersion": 36,
  "version": 1,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "stream",
        "type": "query",
        "query": "label_values(tsa_system_health_score, stream_id)",
        "refresh": 1,
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "label": "Focus Stream"
      }
    ]
  },
  "panels": [
    {
      "title": "GLOBAL MONITORING MATRIX (CLICK TO FOCUS)",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_system_health_score",
          "legendFormat": "{{stream_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "range",
              "options": {
                "from": 90,
                "to": 100,
                "result": {
                  "color": "green",
                  "text": "STABLE"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 70,
                "to": 90,
                "result": {
                  "color": "yellow",
                  "text": "DEGRADED"
                }
              }
            },
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 70,
                "result": {
                  "color": "red",
                  "text": "CRITICAL"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "dark-red",
                  "text": "LOST"
                }
              }
            }
          ],
          "links": [
            {
              "title": "Jump to ${__series.name} Focus View",
              "url": "/d/stream-focus?var-stream=${__series.name}",
              "targetBlank": false
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "justifyMode": "center",
        "textMode": "name",
        "orientation": "horizontal"
      }
    },
    {
      "type": "row",
      "title": "TIER 1: MASTER CONTROL CONSOLE (SIGNAL STATUS)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "SIGNAL PRESENCE",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_system_signal_locked{stream_id=\"$stream\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "LOST",
                  "color": "red"
                },
                "1": {
                  "text": "LOCKED",
                  "color": "green"
                }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "gauge",
      "title": "SIGNAL FIDELITY",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 6,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_system_health_score{stream_id=\"$stream\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent"
        }
      }
    },
    {
      "type": "stat",
      "title": "ENGINE DETERMINISM",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_system_internal_drop_count{stream_id=\"$stream\"}",
          "legendFormat": "Drops"
        },
        {
          "expr": "tsa_system_worker_overruns{stream_id=\"$stream\"}",
          "legendFormat": "Overruns"
        }
      ]
    },
    {
      "type": "row",
      "title": "TIER 2: TRANSPORT & LINK INTEGRITY (SRT/MDI)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Link Capacity",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_metrology_physical_bitrate_bps{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "SRT NAK",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 6,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_srt_nak_count{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "SRT RTT",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 12,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_srt_rtt_ms{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "MDI DF",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_transport_mdi_df_ms{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "row",
      "title": "TIER 3: ETR 290 P1 (CRITICAL COMPLIANCE)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Sync Loss",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_compliance_tr101290_p1_sync_loss_total{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PAT Error",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 6,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_compliance_tr101290_p1_pat_errors_total{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "PMT Error",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 12,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_compliance_tr101290_p1_pmt_errors_total{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "CC Error",
      "gridPos": {
        "h": 3,
        "w": 6,
        "x": 18,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_compliance_tr101290_p1_cc_errors_total{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "row",
      "title": "TIER 4: ETR 290 P2 (CLOCK & TIMING)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "PCR JITTER & ACCURACY",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_metrology_pcr_jitter_ms{stream_id=\"$stream\"}"
        }
      ]
    },
    {
      "type": "row",
      "title": "TIER 5: SERVICE PAYLOAD DYNAMICS (MUX)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "PID BITRATE REVENUE",
      "gridPos": {
        "h": 15,
        "w": 18,
        "x": 0,
        "y": 31
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (pid, type) (tsa_metrology_pid_bitrate_bps{stream_id=\"$stream\"})"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "type": "row",
      "title": "TIER 6: ESSENCE QUALITY & TEMPORAL STABILITY",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 46
      },
      "collapsed": false
    },
    {
      "type": "row",
      "title": "TIER 7: ALARM RECAP & FORENSIC AUDIT TRAIL",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 56
      },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "ALARM EVENT LOG",
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 57
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "increase(tsa_compliance_tr101290_p1_cc_errors_total{stream_id=\"$stream\"}[1h]) > 0",
          "format": "table"
        }
      ]
    }
  ],
  "editable": true
}