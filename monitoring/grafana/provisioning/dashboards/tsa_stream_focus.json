{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "liveNow": false,
  "panels": [
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "title": "TIER 1: MASTER CONTROL CONSOLE (SIGNAL STATUS)",
      "type": "row",
      "collapsed": false
    },
    {
      "title": "SIGNAL PRESENCE",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "tsa_signal_lock_status{stream_id=\"$stream\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "red",
                  "text": "LOST"
                },
                "1": {
                  "color": "green",
                  "text": "LOCKED"
                }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "title": "FAILURE DOMAIN",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 4,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg_over_time(tsa_health_score{stream_id=\"$stream\"}[15s])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "title": "SIGNAL FIDELITY",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "tsa_health_score{stream_id=\"$stream\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "title": "ENGINE DETERMINISM",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "tsa_internal_analyzer_drop{stream_id=\"$stream\"} + tsa_worker_slice_overruns{stream_id=\"$stream\"}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "title": "TIER 2: TRANSPORT & LINK INTEGRITY (SRT/MDI)",
