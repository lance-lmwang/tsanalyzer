    {
      "title": "NULL PACKET DENSITY (%)",
      "type": "gauge",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 27
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "((tsa_pid_bitrate_bps{stream_id=\"$stream\",pid=\"0x1fff\"} / ignoring(pid,type) group_left sum by(stream_id) (tsa_pid_bitrate_bps{stream_id=\"$stream\"})) * 100) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "blue",
                "value": 20
              }
            ]
          }
        }
      }
