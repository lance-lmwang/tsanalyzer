{
  "uid": "stream-focus",
  "title": "TsAnalyzer Pro - STREAM FOCUS",
  "refresh": "5s",
  "schemaVersion": 36,
  "version": 1,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "stream",
        "type": "query",
        "query": "label_values(tsa_health_score, stream_id)",
        "refresh": 1,
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "label": "Focus Stream"
      }
    ]
  },
  "panels": [
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "title": "TIER 1 \u2014 FAILURE DOMAIN COMMAND BAR",
      "type": "row",
      "panels": []
    },
    {
      "type": "stat",
      "title": "FAILURE DOMAIN",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "avg_over_time(tsa_health_score{stream_id=\"$stream\"}[15s])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "\u2705 SIGNAL OPTIMAL",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "\u26a0\ufe0f NETWORK IMPAIRMENT",
                  "color": "yellow"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "\u2622\ufe0f ENCODER INSTABILITY",
                  "color": "orange"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "3": {
                  "text": "\ud83d\udea8 MULTI-CAUSAL CRITICAL",
                  "color": "red"
                }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "title": "TIER 2 \u2014 HYBRID DIAGNOSTIC MATRIX",
      "type": "row",
      "panels": []
    },
    {
      "type": "stat",
      "title": "Link Capacity",
      "gridPos": {
        "h": 2,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_physical_bitrate_bps{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "SRT NAK",
      "gridPos": {
        "h": 2,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_tr101290_p1_cc_error{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "Buffer Margin",
      "gridPos": {
        "h": 2,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "mdi_df{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "SRT RTT",
      "gridPos": {
        "h": 2,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_srt_rtt_ms{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "Sync Loss",
      "gridPos": {
        "h": 2,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_tr101290_p1_sync_loss{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "PAT Error",
      "gridPos": {
        "h": 2,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_pat_error_count{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "PMT Error",
      "gridPos": {
        "h": 2,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_pmt_error_count{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "type": "stat",
      "title": "CC Error",
      "gridPos": {
        "h": 2,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_tr101290_p1_cc_error{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "justifyMode": "center"
      }
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "title": "TIER 3 \u2014 ESSENCE & BITRATE ANALYSIS",
      "type": "row",
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "BITRATE ENVELOPE",
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "avg_over_time(tsa_physical_bitrate_bps{stream_id=\"$stream\"}[$__interval])",
          "legendFormat": "Avg"
        },
        {
          "expr": "max_over_time(tsa_physical_bitrate_bps{stream_id=\"$stream\"}[$__interval])",
          "legendFormat": "Max"
        },
        {
          "expr": "min_over_time(tsa_physical_bitrate_bps{stream_id=\"$stream\"}[$__interval])",
          "legendFormat": "Min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "opacity"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "AV SYNC / GOP",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_essence_av_sync_ms{stream_id=\"$stream\"}",
          "legendFormat": "AV Sync (ms)"
        }
      ]
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "title": "TIER 4 \u2014 PREDICTIVE HORIZON",
      "type": "row",
      "panels": []
    },
    {
      "type": "stat",
      "title": "RST SURVIVAL",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_rst_network_seconds{stream_id=\"$stream\"}"
        }
      ],
      "options": {
        "textMode": "value_and_name",
        "colorMode": "value"
      }
    },
    {
      "type": "timeseries",
      "title": "PID INVENTORY",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum by (pid) (tsa_pid_bitrate_bps{stream_id=\"$stream\"})"
        }
      ]
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "title": "TIER 5 \u2014 OPERATIONAL AUDIT TRAIL",
      "type": "row",
      "panels": []
    },
    {
      "type": "logs",
      "title": "OPERATIONAL AUDIT TRAIL",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "datasource": {
        "type": "loki"
      },
      "targets": [
        {
          "expr": "{stream_id=\"$stream\"}"
        }
      ]
    }
  ],
  "editable": true
}