{
  "uid": "tsanalyzer-appliance-noc-v4-3",
  "title": "TsAnalyzer Pro - Appliance NOC (v4.3)",
  "refresh": "1s",
  "version": 430,
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "stream_id",
        "type": "query",
        "query": "label_values(tsa_health_score{instance=\"host.docker.internal:8081\"}, stream_id)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "TIER 0: GLOBAL FLEET STATUS",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Live Ingress Bitrate",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "sum(tsa_physical_bitrate_bps{instance=\"host.docker.internal:8081\"})",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      }
    },
    {
      "type": "stat",
      "title": "Active Appliance Streams",
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "count(tsa_health_score{instance=\"host.docker.internal:8081\"})",
          "legendFormat": "Streams"
        }
      ],
      "options": {
        "colorMode": "background"
      }
    },
    {
      "type": "row",
      "title": "TIER 1: STREAM VITALITY",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "type": "stat",
      "title": "HEALTH",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_health_score{instance=\"host.docker.internal:8081\", stream_id=~\"$stream_id\"}",
          "legendFormat": "{{stream_id}}"
        }
      ],
      "options": {
        "colorMode": "background"
      }
    },
    {
      "type": "stat",
      "title": "BITRATE",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_physical_bitrate_bps{instance=\"host.docker.internal:8081\", stream_id=~\"$stream_id\"}",
          "legendFormat": "{{stream_id}}"
        }
      ],
      "options": {
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "INTERNAL DROPS",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_internal_analyzer_drop{instance=\"host.docker.internal:8081\", stream_id=~\"$stream_id\"}",
          "legendFormat": "{{stream_id}}"
        }
      ],
      "options": {
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "title": "OVERRUNS",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_worker_slice_overruns{instance=\"host.docker.internal:8081\", stream_id=~\"$stream_id\"}",
          "legendFormat": "{{stream_id}}"
        }
      ],
      "options": {
        "colorMode": "value"
      }
    },
    {
      "type": "row",
      "title": "TIER 2: BITRATE HISTORY",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      }
    },
    {
      "type": "timeseries",
      "title": "Per-Stream Bitrate",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_physical_bitrate_bps{instance=\"host.docker.internal:8081\", stream_id=~\"$stream_id\"}",
          "legendFormat": "{{stream_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      }
    },
    {
      "type": "row",
      "title": "TIER 3: FLEET INVENTORY",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      }
    },
    {
      "type": "table",
      "title": "Active Inventory",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "tsa_health_score{instance=\"host.docker.internal:8081\"}",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "color-background"
          }
        }
      }
    }
  ]
}