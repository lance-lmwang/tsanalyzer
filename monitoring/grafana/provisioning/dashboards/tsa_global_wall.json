{
  "uid": "global-wall",
  "title": "TsAnalyzer Pro - UNIFIED NOC v4.0",
  "refresh": "5s",
  "schemaVersion": 36,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "stream",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(tsa_system_health_score, stream_id)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "label": "Focus Stream"
      }
    ]
  },
  "panels": [
    {
      "title": "FLEET STATUS WALL (ALL STREAMS)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "tsa_system_health_score", "legendFormat": "{{stream_id}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": [] },
        "orientation": "horizontal",
        "textMode": "name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "type": "row",
      "title": "TIERED DIAGNOSTICS: $stream",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "collapsed": false
    },
    {
      "title": "L1/L2: INTEGRITY (CC ERRORS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum by (stream_id) (increase(tsa_compliance_tr101290_errors{stream_id=\"$stream\"}[1m]))", "legendFormat": "Violation Rate" }
      ]
    },
    {
      "title": "L3: TIMING (PCR JITTER)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "tsa_metrology_pcr_jitter_ms{stream_id=\"$stream\"}", "legendFormat": "Jitter (ms)" }
      ]
    },
    {
      "title": "L4: BITRATE DYNAMICS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "tsa_metrology_physical_bitrate_bps{stream_id=\"$stream\"} / 1000000", "legendFormat": "Mbps" }
      ]
    },
    {
      "title": "L5: BUFFER (RST PREDICTIVE)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "tsa_predictive_rst_network_seconds{stream_id=\"$stream\"}", "legendFormat": "RST (s)" }
      ]
    },
    {
      "title": "L6: CONTENT VITALS (FPS)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "tsa_essence_video_fps{stream_id=\"$stream\"}", "legendFormat": "FPS" }
      ]
    }
  ]
}
